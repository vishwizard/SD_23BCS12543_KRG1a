        <mxCell id="api-endpoints" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontColor=#000000;" value="&lt;div style=&quot;text-align: left; font-size: 12px; padding: 5px;&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;b style=&quot;&quot;&gt;Auth&lt;/b&gt;&lt;br&gt;POST /api/auth/register&lt;br&gt;POST /api/auth/login&lt;br&gt;GET  /api/auth/profile 🔒&lt;br&gt;PUT  /api/auth/profile 🔒&lt;br&gt;POST /api/auth/reset 🔒&lt;br&gt;&lt;br&gt;&lt;b style=&quot;&quot;&gt;Stocks&lt;/b&gt;&lt;br&gt;GET /api/stocks/search?q={query}&lt;br&gt;GET /api/stocks/quote/{symbol}&lt;br&gt;GET /api/stocks/profile/{symbol}&lt;br&gt;GET /api/stocks/history/{symbol}?interval={daily|weekly|monthly}&lt;br&gt;GET /api/stocks/trending&lt;br&gt;GET /api/stocks/market-status&lt;br&gt;&lt;br&gt;&lt;b style=&quot;&quot;&gt;Trading&lt;/b&gt;&lt;br&gt;POST /api/trading/buy 🔒 {symbol, quantity}&lt;br&gt;POST /api/trading/sell 🔒 {symbol, quantity}&lt;br&gt;GET  /api/trading/history 🔒 ?page=&amp;amp;limit=&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="320" width="380" x="100" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="api-endpoints-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontColor=#000000;" value="&lt;div style=&quot;text-align: left; font-size: 12px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Portfolio&lt;/b&gt;&lt;br&gt;GET /api/portfolio 🔒&lt;br&gt;GET /api/portfolio/performance 🔒&lt;br&gt;&lt;br&gt;&lt;b style=&quot;&quot;&gt;Watchlist&lt;/b&gt;&lt;br&gt;GET    /api/watchlist 🔒&lt;br&gt;POST   /api/watchlist 🔒 {symbol, name}&lt;br&gt;DELETE /api/watchlist/{symbol} 🔒&lt;br&gt;&lt;br&gt;&lt;b style=&quot;&quot;&gt;AI (Gemini)&lt;/b&gt;&lt;br&gt;GET  /api/ai/analyze/{symbol} 🔒&lt;br&gt;POST /api/ai/chat 🔒 {message}&lt;br&gt;GET  /api/ai/portfolio-insights 🔒&lt;br&gt;POST /api/ai/sentiment 🔒 {headlines[]}&lt;br&gt;&lt;br&gt;&lt;b style=&quot;&quot;&gt;News&lt;/b&gt;&lt;br&gt;GET /api/news/market?category={general|forex|crypto}&lt;br&gt;GET /api/news/company/{symbol}&lt;br&gt;&lt;br&gt;&lt;b style=&quot;&quot;&gt;Leaderboard&lt;/b&gt;&lt;br&gt;GET /api/leaderboard?type={pnl|trades|level}&lt;br&gt;&lt;br&gt;🔒 = Requires JWT Bearer Token&lt;/div&gt;" vertex="1">
          <mxGeometry height="320" width="380" x="500" y="1010" as="geometry" />
        </mxCell>
        <mxCell id="schema-title" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#FFFFFF;" value="&lt;font style=&quot;font-size: 22px;&quot;&gt;&lt;b&gt;🗃️ MongoDB Schema Design&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="350" x="100" y="1370" as="geometry" />
        </mxCell>
        <mxCell id="schema-user" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontColor=#000000;" value="&lt;div style=&quot;text-align: left; font-size: 11px;&quot;&gt;&lt;b style=&quot;font-size: 14px;&quot;&gt;📦 User&lt;/b&gt;&lt;br&gt;&lt;br&gt;_id: ObjectId (PK)&lt;br&gt;name: String (required, trim)&lt;br&gt;email: String (required, unique)&lt;br&gt;password: String (bcrypt hashed)&lt;br&gt;avatar: String&lt;br&gt;balance: Number (default: 100000)&lt;br&gt;initialBalance: Number (100000)&lt;br&gt;&lt;br&gt;&lt;b&gt;holdings: [&lt;/b&gt;&lt;br&gt;&amp;nbsp; { symbol, name, quantity,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;avgPrice, totalInvested }&lt;br&gt;&lt;b&gt;]&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;achievements: [&lt;/b&gt;&lt;br&gt;&amp;nbsp; { id, title, description,&lt;br&gt;&amp;nbsp;&amp;nbsp;&amp;nbsp;icon, unlockedAt }&lt;br&gt;&lt;b&gt;]&lt;/b&gt;&lt;br&gt;&lt;br&gt;totalTrades: Number (0)&lt;br&gt;profitableTrades: Number (0)&lt;br&gt;totalPnL: Number (0)&lt;br&gt;level: Number (1)&lt;br&gt;xp: Number (0)&lt;br&gt;createdAt, updatedAt&lt;/div&gt;" vertex="1">
          <mxGeometry height="380" width="220" x="100" y="1410" as="geometry" />
        </mxCell>
        <mxCell id="schema-transaction" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontColor=#000000;" value="&lt;div style=&quot;text-align: left; font-size: 11px;&quot;&gt;&lt;b style=&quot;font-size: 14px;&quot;&gt;📦 Transaction&lt;/b&gt;&lt;br&gt;&lt;br&gt;_id: ObjectId (PK)&lt;br&gt;user: ObjectId → User (FK)&lt;br&gt;symbol: String (required)&lt;br&gt;name: String (required)&lt;br&gt;type: Enum [&quot;BUY&quot;, &quot;SELL&quot;]&lt;br&gt;quantity: Number&lt;br&gt;price: Number&lt;br&gt;total: Number&lt;br&gt;pnl: Number (SELL only)&lt;br&gt;createdAt, updatedAt&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="220" x="340" y="1410" as="geometry" />
        </mxCell>
        <mxCell id="schema-watchlist" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=10;spacingTop=5;fontColor=#000000;" value="&lt;div style=&quot;text-align: left; font-size: 11px;&quot;&gt;&lt;b style=&quot;font-size: 14px;&quot;&gt;📦 Watchlist&lt;/b&gt;&lt;br&gt;&lt;br&gt;_id: ObjectId (PK)&lt;br&gt;user: ObjectId → User (FK)&lt;br&gt;symbol: String (required)&lt;br&gt;name: String (required)&lt;br&gt;addedAt: Date&lt;br&gt;alertPrice: Number (null)&lt;br&gt;notes: String&lt;br&gt;createdAt, updatedAt&lt;br&gt;&lt;br&gt;&lt;b&gt;Index:&lt;/b&gt; { user, symbol } UNIQUE&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="220" x="580" y="1410" as="geometry" />
        </mxCell>
        <mxCell id="schema-rel-1" edge="1" parent="1" source="schema-user" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#b85450;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;fontColor=#000000;" target="schema-transaction">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="schema-rel-2" edge="1" parent="1" source="schema-user" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#b85450;startArrow=ERone;startFill=0;endArrow=ERmany;endFill=0;fontColor=#000000;" target="schema-watchlist">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="210" y="1830" />
              <mxPoint x="690" y="1830" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="fr-title" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#FFFFFF;" value="&lt;font style=&quot;font-size: 22px;&quot;&gt;&lt;b&gt;✅ Functional Requirements&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="400" x="100" y="1880" as="geometry" />
        </mxCell>
        <mxCell id="fr-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;spacingRight=15;fontColor=#000000;" value="&lt;div style=&quot;text-align: left; font-size: 13px; line-height: 1.8;&quot;&gt;&lt;b&gt;Authentication:&lt;/b&gt; Users must register/login with email &amp;amp; password. JWT-based session management with 30-day token expiry.&lt;br&gt;&lt;br&gt;&lt;b&gt;Stock Discovery:&lt;/b&gt; Users can search stocks by symbol or name, view real-time quotes, historical charts (daily/weekly/monthly), company profiles, and trending stocks.&lt;br&gt;&lt;br&gt;&lt;b&gt;Paper Trading:&lt;/b&gt; Users start with \$100,000 virtual cash. They can buy and sell stocks at real-time market prices. System tracks quantity, average cost, P&amp;amp;L per holding.&lt;br&gt;&lt;br&gt;&lt;b&gt;Portfolio Management:&lt;/b&gt; Live portfolio valuation with current prices, total P&amp;amp;L, day change, win rate, net worth, and allocation chart.&lt;br&gt;&lt;br&gt;&lt;b&gt;AI Analysis:&lt;/b&gt; AI-powered stock recommendations (Strong Buy → Strong Sell), risk assessment, sentiment analysis, portfolio health scoring, and educational chatbot.&lt;br&gt;&lt;br&gt;&lt;b&gt;Watchlist:&lt;/b&gt; Users can add/remove stocks to track, with live price updates.&lt;br&gt;&lt;br&gt;&lt;b&gt;Gamification:&lt;/b&gt; XP earned from trades, level progression, 9 achievement badges unlocked automatically.&lt;br&gt;&lt;br&gt;&lt;b&gt;Leaderboard:&lt;/b&gt; Global rankings sorted by P&amp;amp;L, total trades, or level/XP.&lt;br&gt;&lt;br&gt;&lt;b&gt;News:&lt;/b&gt; Real-time market news and company-specific news with AI sentiment analysis.&lt;/div&gt;" vertex="1">
          <mxGeometry height="420" width="700" x="100" y="1920" as="geometry" />
        </mxCell>
        <mxCell id="nfr-title" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#FFFFFF;" value="&lt;font style=&quot;font-size: 22px;&quot;&gt;&lt;b&gt;⚡ Non-Functional Requirements&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="450" x="100" y="2380" as="geometry" />
        </mxCell>
        <mxCell id="nfr-box" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=15;spacingTop=10;spacingRight=15;fontColor=#000000;" value="&lt;div style=&quot;text-align: left; font-size: 13px; line-height: 1.8;&quot;&gt;&lt;b&gt;Performance:&lt;/b&gt; Server-side caching with NodeCache (60s–3600s TTL per endpoint). Parallel API calls using Promise.allSettled to prevent waterfalls.&lt;br&gt;&lt;br&gt;&lt;b&gt;Security:&lt;/b&gt; Passwords hashed with bcrypt (12 salt rounds). JWT authentication for all protected routes. Rate limiting: 60 req/min for APIs, 10 req/15min for auth.&lt;br&gt;&lt;br&gt;&lt;b&gt;Availability:&lt;/b&gt; Graceful error handling — if one API fails (e.g., Alpha Vantage), the page still renders with available data. Cache serves stale data during API outages.&lt;br&gt;&lt;br&gt;&lt;b&gt;Consistency:&lt;/b&gt; Trading operations (buy/sell) are atomic at the MongoDB document level. Balance checks prevent overspending. Quantity checks prevent overselling.&lt;br&gt;&lt;br&gt;&lt;b&gt;Scalability:&lt;/b&gt; Stateless JWT auth allows horizontal scaling. MongoDB supports sharding. Cache reduces external API load by ~90%.&lt;br&gt;&lt;br&gt;&lt;b&gt;Responsiveness:&lt;/b&gt; Fully responsive UI (mobile + desktop). TailwindCSS utility classes. Vite for sub-second HMR during development.&lt;/div&gt;" vertex="1">
          <mxGeometry height="440" width="700" x="100" y="2420" as="geometry" />
        </mxCell>
        <mxCell id="trade-flow-title" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#FFFFFF;" value="&lt;font style=&quot;font-size: 22px;&quot;&gt;&lt;b&gt;💹 Buy/Sell Trade Flow&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="35" width="350" x="950" y="970" as="geometry" />
        </mxCell>
