        <mxCell id="jwt-steps" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#000000;" value="1️⃣ User sends email + password&lt;br&gt;2️⃣ Server validates → bcrypt compare&lt;br&gt;3️⃣ Server issues JWT (30d expiry)&lt;br&gt;4️⃣ Client stores in localStorage&lt;br&gt;5️⃣ All requests include Bearer token&lt;br&gt;6️⃣ Middleware decodes → injects user to req" vertex="1">
