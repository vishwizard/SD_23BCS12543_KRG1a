        <mxCell id="pQRZkbDEzMrFR3s9crdf-16" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;Post Schema&lt;/font&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;post_id : String&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;description : String&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;likes : Number&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;comments : Object (Comment Schema)&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;username: String&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;" vertex="1">
